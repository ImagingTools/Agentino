schema {
	query: Query
	mutation: Mutation
	subscription: Subscription
	namespace: agentino
	version: 1.0
}

import {
	"../../../../ImtCore/Sdl/imtbase/1.0/ImtCollection.sdl"
}

type AgentListInputViewParams {
	count: Int
	offset: Int
	filterModel: String
}

input AgentListInput {
	viewParams: AgentListInputViewParams
	# "status" is computed live (connection state + enrollment state, never stored - see
	# CAgentCollectionControllerComp::ComputeAgentStatus), so the generic ComplexFilter/
	# filterModel path can't see it - the server filters directly on this instead.
	# One of: "" (no filter), "Pending", "Approved", "Suspended", "Rejected", "Revoked".
	status: String
}

type AgentItem {
	id: ID!
	typeId: ID!
	name: String!
	description: String
	added: String
	computerName: String
	services: String
	status: String
	enrollmentStatus: String
	lastConnection: String
	version: String
}

type AgentStatusCounts {
	all: Int!
	pending: Int!
	approved: Int!
	suspended: Int!
	rejected: Int!
	revoked: Int!
}

type AgentListPayload{
	items: [AgentItem]!
	# Always the full unfiltered breakdown (independent of this response's own "status" filter),
	# so filter buttons can label themselves ("Pending (2)") without a second round trip.
	counts: AgentStatusCounts
	# ListObjects always returns pagesCount/totalCount (same shape as MessageListPayload).
	# Required for web fromObject() — unknown object keys call createComponent() and crash if missing.
	notification: NotificationItem
}

type AgentData {
	id: ID!
	name: String!
	description: String
	lastConnection: String
	tracingLevel: Integer
	serviceCount: Int
}

input AgentDataInput {
	id: ID!
	item: AgentData!
}

type Query {
	AgentsList (input: AgentListInput): AgentListPayload!
	GetAgent (input: InputId): AgentData!
}

type Mutation {
	UpdateAgent (input: AgentDataInput): UpdatedNotificationPayload!
	AddAgent (input: AgentDataInput): AddedNotificationPayload!
}

collectionSchema {
	type Agent {
		ref: AgentItem
		operations {
			list: AgentsList
		}
		subtype Agent {
			ref: AgentData
			operations {
				get: GetAgent
				update: UpdateAgent
			}
		}
	}
}
