schema {
	query: Query
	mutation: Mutation
	subscription: Subscription
	namespace: agentino
	version: 1.0
}

import {
	"../../../../ImtCore/Sdl/imtbase/1.0/ImtCollection.sdl"
	"../../../../ImtCore/Sdl/imtbase/1.0/ImtBaseTypes.sdl"
}

type ServiceListInputViewParams {
	count: Int
	offset: Int
	filterModel: String
}

input ServiceListInput {
	viewParams: ServiceListInputViewParams
}

type ServiceItem {
	id: ID!
	typeId: ID!
	name: String!
	description: String
	path: String
	status: String
	version: String
}

type ServiceListPayload{
	items: [ServiceItem]!
	# ListObjects returns pagesCount/totalCount; required for web fromObject() (see AgentListPayload).
	notification: NotificationItem
}

type ExternConnectionInfo {
	id: ID
	description: String
	connectionParam: ServerConnectionParam
}

type InputConnection {
	id: ID
	connectionName: String
	description: String
	serviceTypeId: String
	externConnectionList: [ExternConnectionInfo]
	connectionParam: ServerConnectionParam
}

type DependantConnectionInfo {
	id: ID
	name: String
	connectionParam: ServerConnectionParam
}

# Candidate producers for one output connection, keyed by that connection's usage id
# (the id shared between a consumer's output link and a compatible producer's input).
type OutputConnectionCandidates {
	connectionUsageId: ID!
	candidates: [DependantConnectionInfo]
}

input AvailableConnectionsInput {
	connectionUsageIds: [ID]
}

type AvailableConnectionsPayload {
	outputConnections: [OutputConnectionCandidates]!
}

type OutputConnection {
	id: ID
	connectionName: String
	description: String
	serviceName: String
	serviceTypeId: String
	dependantConnectionId: String
	connectionParam: ServerConnectionParam
}

type ServiceData {
	id: ID!
	name: String!
	description: String
	path: String
	arguments: String
	serviceTypeId: String
	enableVerbose: Boolean
	isAutoStart: Boolean
	tracingLevel: Integer
	startScript: String
	stopScript: String
	settingsPath: String
	version: String
	status: String
	inputConnections: [InputConnection]
	outputConnections: [OutputConnection]
}

input ServiceDataInput {
	id: ID!
	item: ServiceData!
}

input ConnectionUrlInput {
	serviceId: ID!
	connectionId: ID!
	connectionParam: ServerConnectionParam!
}

type UpdateConnectionUrlResponse {
	succesful: Boolean
}

# Standalone, immediate-apply pick of a producer for one Output Connection slot -
# independent of the rest of ServiceData, so choosing a connection does not require
# saving the whole service record. connectionParam is resolved by the server (which can
# see across the whole fleet) and forwarded to the owning agent; clients only ever send
# dependantConnectionId (empty clears the selection).
input SetOutputConnectionInput {
	serviceId: ID!
	connectionId: ID!
	dependantConnectionId: String
	connectionParam: ServerConnectionParam
}

type SetOutputConnectionResponse {
	succesful: Boolean
	connectionParam: ServerConnectionParam
}

enum ServiceStatus {
	UNDEFINED
	STARTING
	STOPPING
	RUNNING
	NOT_RUNNING
	RUNNING_IMPOSSIBLE
}

type ServiceInput {
	serviceId: ID!
}

type ServiceStatusResponse {
	status: ServiceStatus!
}

type LoadPluginInput {
	servicePath: String!
}

type ServiceSettingsPayload {
	serviceId: ID
	path: String
	content: String
	exists: Boolean
}

input ServiceSettingsInput {
	serviceId: ID!
	content: String!
}

type PluginInfo {
	servicePath: String!
	inputConnections: [InputConnection]
	outputConnections: [OutputConnection]
}

type Query {
	ServicesList (input: ServiceListInput): ServiceListPayload!
	GetService (input: InputId): ServiceData!
	GetServiceStatus (input: InputId): ServiceStatusResponse!
	GetServiceSettings (input: ServiceInput): ServiceSettingsPayload!
	AvailableConnections (input: AvailableConnectionsInput): AvailableConnectionsPayload!
}

type Mutation {
	LoadPlugin (input: LoadPluginInput): PluginInfo!
	UpdateService (input: ServiceDataInput): UpdatedNotificationPayload!
	AddService (input: ServiceDataInput): AddedNotificationPayload!
	
	StartService (input: ServiceInput): ServiceStatusResponse!
	StopService (input: ServiceInput): ServiceStatusResponse!
	
	ServicesRemove (input: RemoveElementsInput): RemovedNotificationPayload!
	UpdateConnectionUrl (input: ConnectionUrlInput): UpdateConnectionUrlResponse!
	UpdateServiceSettings (input: ServiceSettingsInput): ServiceSettingsPayload!
	SetOutputConnection (input: SetOutputConnectionInput): SetOutputConnectionResponse!
}

collectionSchema {
	type Service {
		ref: ServiceItem
		operations {
			list: ServicesList
		}
		subtype Service {
			ref: ServiceData
			operations {
				get: GetService
				update: UpdateService
				insert: AddService
			}
		}
	}
}
